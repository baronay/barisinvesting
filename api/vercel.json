{
  "functions": {
    "api/analyze.js":           { "maxDuration": 30 },
    "api/auth.js":              { "maxDuration": 10 },
    "api/bist-ratios.js":       { "maxDuration": 15 },
    "api/tez-admin.js":         { "maxDuration": 10 },
    "api/market.js":            { "maxDuration": 15 },
    "api/garp-bildirim.js":     { "maxDuration": 10 },
    "api/haftalik-secimler.js": { "maxDuration": 10 },
    "api/forum.js":             { "maxDuration": 10 },
    "api/logo.js":              { "maxDuration": 10 },
    "api/watchlist.js":         { "maxDuration": 10 },
    "api/fair-value.js":        { "maxDuration": 20 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
